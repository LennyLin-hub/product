<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.product.pps.mapper.ProductionBatchMapper">
    <resultMap id="ProductionBatchMap" type="com.product.domain.vo.ProductionBatchVO">
        <id property="batchId" column="batch_id"></id>
        <result property="orderLineId" column="order_line_id"></result>
        <result property="orderId" column="order_id"></result>
        <result property="productName" column="product_name"></result>
        <result property="batchQty" column="batch_qty"></result>
        <result property="status" column="status"></result>
        <result property="plannedStart" column="planned_start"></result>
        <result property="plannedEnd" column="planned_end"></result>
        <result property="dueDate" column="due_date"></result>
    </resultMap>

    <!-- MyBatis-Plus 已提供通用 CRUD，这里按需补充自定义 SQL -->
    <sql id="selectProductionBatchVO">
        select pb.batch_id, pb.order_line_id, pb.batch_qty, pb.status, pb.planned_start, pb.planned_end,
               o.order_id, o.due_date, p.product_name
            from production_batch pb
        left join order_line ol
            on pb.order_line_id = ol.order_line_id
        left join customer_order o
            on ol.order_id = o.order_id
        left join product p
            on ol.product_id = p.product_id
    </sql>

    <select id="selectProductionBatchPage" resultMap="ProductionBatchMap">
        <include refid="selectProductionBatchVO"></include>
        <where>
            <if test="batchSearchDTO.orderId != null and batchSearchDTO.orderId != ''">
                o.order_id = #{batchSearchDTO.orderId}
            </if>
            <if test="batchSearchDTO.orderLineId != null">
                and pb.order_line_id = #{batchSearchDTO.orderLineId}
            </if>
            <if test="batchSearchDTO.status != null">
                and pb.status = #{batchSearchDTO.status}
            </if>
            <if test="batchSearchDTO.params.beginPlannedStart != null">
                and date_format(pb.planned_start) &gt; date_format(#{batchSearchDTO.params.beginPlannedStart})
            </if>
            <if test="batchSearchDTO.params.endPlannedStart != null">
                and date_format(pb.planned_start) &lt; date_format(#{batchSearchDTO.params.endPlannedStart})
            </if>
            <if test="batchSearchDTO.params.beginPlannedEnd != null">
                and date_format(pb.planned_end) &gt; date_format(#{batchSearchDTO.params.beginPlannedEnd})
            </if>
            <if test="batchSearchDTO.params.endPlannedEnd != null">
                and date_format(pb.planned_end) &lt; date_format(#{batchSearchDTO.params.beginPlannedEnd})
            </if>
        </where>
    </select>
</mapper>
